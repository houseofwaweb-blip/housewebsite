# commercial font files — ignore globally, allow the ones the app needs
**/*.woff
**/*.woff2
**/*.otf
**/*.ttf
!public/fonts/*.woff
!public/fonts/*.woff2

# large binary assets
*.zip
*.pdf
*.psd
*.ai
*.sketch

# brand assets — keep SVG logos, ignore everything else
brand-assets/patterns/
brand-assets/style guide/
brand-assets/almanac/

# mockup patterns (large PNGs)
mockups/pattern-*.png
mockups/fonts/

# WP migration raw data
src/lib/hearth-data/wp-import/articles.raw.json

