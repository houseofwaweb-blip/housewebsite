# =============================================================================
# House of Willow Alexander × HoWA — Environment Variables
# =============================================================================
#
# This file is loaded automatically by Next.js in dev.
# Gitignored — safe to put real secrets here.
#
# Fill in as you create each account. Nothing breaks on empty values in dev
# until the code actually hits that service (graceful degrades built in).
#
# Reference: platform/CLAUDE.md → "Env var inventory"
# =============================================================================

# -----------------------------------------------------------------------------
# CORE SITE
# -----------------------------------------------------------------------------

# Canonical site URL. Used for OG tags, sitemap, absolute URLs.
#   Dev:        http://localhost:4000
#   Production: https://willowalexander.co.uk
NEXT_PUBLIC_SITE_URL=http://localhost:4000


# -----------------------------------------------------------------------------
# HOWA PRODUCT APP (built separately — the place Start HoWA CTAs bounce to)
# -----------------------------------------------------------------------------

# Where Start HoWA CTAs point. Even a parked subdomain is fine pre-launch.
#   Dev:        http://localhost:3001 (if running HoWA Product locally)
#   Production: https://app.willowalexander.co.uk (or your chosen domain)
NEXT_PUBLIC_HOWA_APP_URL=

# Fallback flag. When `false`, Start HoWA routes to /howa/coming-soon
# and the header CTA label swaps to "Book consultation".
# Flip to `true` only once HoWA Product is actually reachable.
HOWA_APP_LIVE=false


# -----------------------------------------------------------------------------
# SANITY (editorial CMS)
# -----------------------------------------------------------------------------
# Sign up:     https://www.sanity.io/manage
# Steps:       Create project → create "production" dataset → Settings → API → Tokens
# What I need: project ID (shown top-right in dashboard), dataset name, read token
# -----------------------------------------------------------------------------

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_READ_TOKEN=

# Draft-mode preview route secret. Server-only (no NEXT_PUBLIC_ prefix).
# Generate with: openssl rand -base64 32
SANITY_PREVIEW_SECRET=


# -----------------------------------------------------------------------------
# SHOPIFY (headless commerce)
# -----------------------------------------------------------------------------
# Store admin: Apps → Develop apps → Create app → Configure Storefront API
# Scopes:      unauthenticated_read_product_listings
#              unauthenticated_write_checkouts
# What I need: store domain (ends in .myshopify.com) + Storefront access token
# -----------------------------------------------------------------------------

SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=


# -----------------------------------------------------------------------------
# SUPABASE (form submissions + waitlists)
# -----------------------------------------------------------------------------
# Sign up:     https://supabase.com/dashboard
# Steps:       Create project → Settings → API
# What I need: Project URL, anon key, service_role key
# -----------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_ANON_KEY=

# !!! SERVER-ONLY — NEVER IN 'use client' FILES !!!
# Bypasses RLS, full DB access. Used only in /api/* route handlers.
# A lint rule + runtime guard prevent leakage.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# UPSTASH REDIS (rate-limiting + postcode cache)
# -----------------------------------------------------------------------------
# Sign up:     https://console.upstash.com
# Steps:       Create Redis database (free tier fine for launch) → Details → REST API
# -----------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (invisible anti-abuse on forms)
# -----------------------------------------------------------------------------
# Sign up:     https://dash.cloudflare.com → Turnstile
# Steps:       Add site (hostname: willowalexander.co.uk + localhost) → get both keys
# -----------------------------------------------------------------------------

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
# SENTRY (error + performance monitoring)
# -----------------------------------------------------------------------------
# Sign up:     https://sentry.io/signup/
# Steps:       Create project (Next.js template) → Settings → Client Keys → copy DSN
# Free tier handles launch volume comfortably.
# -----------------------------------------------------------------------------

# Public DSN — client-side errors (browser)
NEXT_PUBLIC_SENTRY_DSN=

# Server DSN — API routes + SSR (can be same project, usually same DSN)
SENTRY_DSN=

# Set by CI to git SHA — maps errors to specific deploys. Leave empty in dev.
SENTRY_RELEASE=


# -----------------------------------------------------------------------------
# CONTACT FORM ROUTING (decide during build, swap any time)
# -----------------------------------------------------------------------------
# Which inbox gets each topic. Placeholder values are fine until you decide.
# -----------------------------------------------------------------------------

CONTACT_INBOX_DEFAULT=hello@willowalexander.co.uk
CONTACT_INBOX_DESIGN=design@willowalexander.co.uk
CONTACT_INBOX_SERVICES=bookings@willowalexander.co.uk
CONTACT_INBOX_PROTECT=protect@willowalexander.co.uk
CONTACT_INBOX_SHOP=shop@willowalexander.co.uk
CONTACT_INBOX_PRESS=press@willowalexander.co.uk


# =============================================================================
# OPS ONLY — NEVER SHIP TO VERCEL DEPLOY ENV
# =============================================================================
# Use from local CLI / CI only. Store in a password manager, not in production.
# Uncomment when running the relevant operation.
# =============================================================================

# Sanity write/management token (content agent uploads, redirect seeding)
# Generate: sanity.io/manage → Project → API → Tokens → "Editor" or higher role
# SANITY_MANAGEMENT_TOKEN=

# Shopify Admin API token (Woo → Shopify migration, metafield definitions)
# Generate: Shopify admin → Apps → Develop apps → (your app) → Admin API
# Scopes: write_products, write_content, read_orders, write_inventory
# SHOPIFY_ADMIN_TOKEN=

# Legacy WooCommerce (one-time migration source)
# Generate: wp-admin → WooCommerce → Settings → Advanced → REST API
# WOOCOMMERCE_URL=https://willowalexander.co.uk
# WOOCOMMERCE_CONSUMER_KEY=
# WOOCOMMERCE_CONSUMER_SECRET=

# Sentry source-map upload (CI only)
# Generate: sentry.io → User Settings → Auth Tokens
# SENTRY_AUTH_TOKEN=


# =============================================================================
# DEV ONLY
# =============================================================================

# Enable verbose logs
DEBUG=
